@model List<Book>

@{
    ViewData["Title"] = "Books";
}

<div class="books-container">
    <div class="books-header">
        <div class="header-content">
            <h1>Discover Books</h1>
            <p class="sub-header">Explore our collection of amazing books</p>
        </div>
    </div>

    <div class="books-grid">
        @foreach(var item in Model)
        {
            <div class="book-card">
                @using (Html.BeginForm("Details", "Books", FormMethod.Get))
                {
                    <input type="hidden" name="id" value="@item.BookID" />
                    <button type="submit" class="book-card-button">
                        <div class="book-cover">
                            <div class="book-title-preview">@item.BookName</div>
                        </div>
                        <div class="book-details">
                            <h3>@item.BookName</h3>
                            <p class="book-author">@item.BookAuthor</p>
                            <p class="book-info">
                                <span class="language-badge">@(item.Language?.Name ?? "N/A")</span>
                                <span class="price-badge">$@item.BookPrice</span>
                            </p>
                        </div>
                    </button>
                }
            </div>
        }
        
        <!-- More Books Card -->
        <div class="book-card more-books">
            <div class="book-cover coming-soon">
                <i class="bi bi-three-dots"></i>
            </div>
            <div class="book-details">
                <h3>More Books</h3>
                <p class="book-author">Coming Soon</p>
                <p class="book-info">
                    <span class="coming-soon-badge">Stay Tuned!</span>
                </p>
            </div>
        </div>
    </div>

    <div class="overlay @(ViewData["SelectedBook"] != null ? "active" : "")"></div>

    @if (ViewData["SelectedBook"] != null)
    {
        var book = (Book)ViewData["SelectedBook"];
        <div class="book-details-panel @(ViewData["SelectedBook"] != null ? "active" : "")">
            <div class="details-content">
                <div class="details-header">
                    <h2>@book.BookName</h2>
                    @using (Html.BeginForm("Index", "Books", FormMethod.Get))
                    {
                        <button type="submit" class="close-button">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    }
                </div>
                
                <div class="book-info-container">
                    <div class="book-cover-large">
                        <div class="book-title-preview">@book.BookName</div>
                    </div>

                    <div class="book-info-detailed">
                        <p class="author">By @book.BookAuthor</p>
                        <p class="synopsis">@book.Synopsis</p>
                        
                        <div class="badges">
                            <span class="badge">@book.Language?.Name</span>
                            @foreach(var genre in book.BookGenres.Select(bg => bg.Genre))
                            {
                                <span class="badge">@genre.Name</span>
                            }
                        </div>

                        <div class="price-section">
                            <span class="price">$@book.BookPrice.ToString("0.00")</span>
                            <div class="action-buttons">
                                <button class="buy-button">Buy Now</button>
                                <button class="wishlist-button">
                                    <i class="bi bi-heart"></i>
                                    Add to Wishlist
                                </button>
                            </div>
                        </div>

                        <div class="publication-info">
                            <p>Published: @book.BookPublishedDate.ToString("MMMM dd, yyyy")</p>
                            @if (book.BookPublishers.Any())
                            {
                                <p>Publisher: @book.BookPublishers.First().Publisher.Name</p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
.books-container {
    padding: 2rem;
    max-width: 1200px;
    margin: 0 auto;
}

.books-header {
    text-align: center;
    margin-bottom: 3rem;
    padding: 2rem 0;
}

.header-content {
    max-width: 800px;
    margin: 0 auto;
}

.books-header h1 {
    font-size: 2.5rem;
    color: #1a73e8;
    margin-bottom: 0.5rem;
}

.sub-header {
    font-size: 1.1rem;
    color: #666;
    margin: 0;
    font-weight: 300;
}

.books-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.5rem;
    padding: 0.5rem;
}

.book-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform 0.2s;
}

.book-card:hover {
    transform: translateY(-5px);
}

.book-cover {
    background: linear-gradient(145deg, #1a73e8, #1557b0);
    width: 150px;
    height: 225px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem auto;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    padding: 1rem;
    color: white;
}

.book-cover i {
    font-size: 2.5rem;
    color: #1a73e8;
    opacity: 0.8;
}

.book-details {
    text-align: center;
    margin-top: 1rem;
}

.book-details h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
}

.book-author, .book-info {
    font-size: 1rem;
    color: #666;
    margin: 0.2rem 0;
}

.book-info {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    margin: 0.5rem 0;
}

.language-badge, .price-badge {
    background: #e8f0fe;
    color: #1a73e8;
    padding: 0.25rem 0.75rem;
    border-radius: 16px;
    font-size: 0.9rem;
}

.book-actions {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
}

.edit-btn, .delete-btn {
    padding: 0.5rem 1rem;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
}

.edit-btn {
    background: #1a73e8;
    color: white;
    text-decoration: none;
}

.delete-btn {
    background: #dc3545;
    color: white;
}

.delete-form {
    margin: 0;
}

.more-books .coming-soon {
    background: linear-gradient(145deg, #e8f0fe, #c8d9f3);
    border: none;
}

.more-books .coming-soon i {
    font-size: 2.5rem;
    color: white;
    opacity: 0.8;
}

.coming-soon-badge {
    background: #e8f0fe;
    color: #1a73e8;
    padding: 0.25rem 0.75rem;
    border-radius: 16px;
    font-size: 0.9rem;
}

.more-books {
    opacity: 0.8;
    transition: opacity 0.2s;
}

.more-books:hover {
    opacity: 1;
}

.book-card-button {
    width: 100%;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    text-align: left;
}

.book-title-preview {
    font-size: 1.1rem;
    font-weight: 500;
    text-align: center;
    word-wrap: break-word;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.4;
}

.book-cover-large .book-title-preview {
    font-size: 1.8rem;
    -webkit-line-clamp: 6;
}

/* Book Details Panel */
.overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(3px);
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease-out;
    z-index: 999;
}

.overlay.active {
    opacity: 1;
    visibility: visible;
}

.book-details-panel {
    position: fixed;
    top: 0;
    left: -500px;
    width: 500px;
    height: 100vh;
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(10px);
    box-shadow: 5px 0 25px rgba(0, 0, 0, 0.1);
    z-index: 1000;
    overflow-y: auto;
    transition: left 0.2s ease-out; /* Add transition here for both open and close */
}

.book-details-panel.active {
    left: 0;
    transition: left 0.2s ease-out; /* Changed from 0.3s to 0.2s */
}

.book-details-panel.closing {
    left: -500px;
    transition: left 0.2 ease-out; /* Changed from 0.3s to 0.2s */
}

.details-content {
    padding: 0 1.5rem 1.5rem 1.5rem;
}

.details-header {
    position: relative;
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.1);
}

.details-header h2 {
    font-size: 1.5rem;
    color: #1a1a1a;
    margin: 0;
    padding-right: 2.5rem;
}

.close-button {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: none;
    border: none;
    color: #666;
    font-size: 1.5rem;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 50%;
    transition: all 0.2s ease;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.close-button:hover {
    background: rgba(0, 0, 0, 0.05);
    color: #1a73e8;
}

/* Book Cover and Info Styles */
.book-info-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.5rem;
}

.book-cover-large {
    background: linear-gradient(145deg, #1a73e8, #1557b0);
    width: 200px;
    height: 300px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
    box-shadow: 0 4px 15px rgba(26, 115, 232, 0.2);
    padding: 1.5rem;
    color: white;
}

.book-info-detailed {
    color: #333;
    text-align: center;
}

.book-info-detailed .author {
    font-size: 1.1rem;
    color: #1a73e8;
    margin-bottom: 0.75rem;
}

.book-info-detailed .synopsis {
    line-height: 1.6;
    margin-bottom: 1rem;
    color: #4a4a4a;
}

.badges {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
}

.badge {
    background: #e8f0fe;
    color: #1a73e8;
    padding: 0.4rem 0.8rem;
    border-radius: 20px;
    font-size: 0.85rem;
}

.price-section {
    margin: 1.5rem 0;
    padding: 1rem;
    background: #f8f9fa;
    border-radius: 12px;
}

.price {
    font-size: 1.5rem;
    color: #1a73e8;
    font-weight: 600;
    display: block;
    margin-bottom: 0.75rem;
}

.action-buttons {
    display: flex;
    gap: 0.75rem;
}

.buy-button, .wishlist-button {
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
    font-weight: 500;
}

.buy-button {
    background: #1a73e8;
    color: white;
    flex: 2;
}

.buy-button:hover {
    background: #1557b0;
}

.wishlist-button {
    background: #e8f0fe;
    color: #1a73e8;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
}

.wishlist-button:hover {
    background: #d2e3fc;
}

.publication-info {
    margin-top: 1.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(0, 0, 0, 0.1);
    color: #666;
    font-size: 0.85rem;
}

/* Add custom scrollbar */
.book-details-panel {
    scrollbar-width: thin;
    scrollbar-color: #1a73e8 rgba(0, 0, 0, 0.1);
}

.book-details-panel::-webkit-scrollbar {
    width: 6px;
}

.book-details-panel::-webkit-scrollbar-track {
    background: rgba(0, 0, 0, 0.1);
    border-radius: 4px;
}

.book-details-panel::-webkit-scrollbar-thumb {
    background-color: #1a73e8;
    border-radius: 4px;
}
</style>